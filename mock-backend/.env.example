# QuickCover Backend — copy this to .env and fill in values

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Supabase connection string)
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# CORS — comma-separated list of allowed frontend origins
# Leave unset in development to allow all origins
# Example: https://quickcover-admin.vercel.app,https://quickcover.vercel.app
CORS_ORIGIN=

# JWT — change this to a long random string in production
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=quickcover-dev-secret-change-in-prod

# OpenWeatherMap API key — free tier covers Current Weather + Air Pollution
# Sign up at: https://openweathermap.org/api
# Used by: live_parametric_triggers.js (weather triggers, AQI, dynamic pricing)
# Leave unset to use mock pricing fallback (demo works without it)
WEATHER_API_KEY=
