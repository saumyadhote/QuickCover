# QuickCover Mobile App — copy this to .env and fill in values
# Expo reads variables prefixed with EXPO_PUBLIC_ at build time

# Backend API URL
# Development (physical device): use your machine's local WiFi IP, e.g. http://192.168.1.x:4000
# Development (simulator): http://localhost:4000
# Production: https://your-render-service.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:4000
