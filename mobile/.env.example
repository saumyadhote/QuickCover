# QuickCover Mobile App — copy this to .env and fill in values
# Expo reads variables prefixed with EXPO_PUBLIC_ at build time

# Backend API URL — choose based on your setup:
# Android emulator (local dev):  http://10.0.2.2:4000 (10.0.2.2 routes to host machine)
# iOS simulator (local dev):     http://localhost:4000
# Physical phone (on WiFi):      http://<your-local-wifi-ip>:4000 (find with ipconfig)
# Production:                    https://your-api-server.com
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000
